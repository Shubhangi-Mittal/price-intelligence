# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The pipeline runs in mock mode locally — credentials are only needed
# to go live against real APIs or cloud infrastructure.
# ─────────────────────────────────────────────────────────────────────────────

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_ENV=development        # development | staging | production
LOG_LEVEL=INFO

# ── eBay API ──────────────────────────────────────────────────────────────────
# Free account at developer.ebay.com
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ── Amazon ────────────────────────────────────────────────────────────────────
# No official resale API. Options:
#   Keepa API (price history): https://keepa.com/#!api
#   Rainforest API:            https://www.rainforestapi.com
KEEPA_API_KEY=
RAINFOREST_API_KEY=

# ── StockX ────────────────────────────────────────────────────────────────────
# No official public API — use stockx-py or scrape product pages
STOCKX_SESSION_TOKEN=

# ── GOAT ─────────────────────────────────────────────────────────────────────
# No official public API — scrape search results with rate limiting
GOAT_AUTH_TOKEN=

# ── Mercari ───────────────────────────────────────────────────────────────────
# Unofficial API via reverse-engineered endpoints
MERCARI_DPOP_KEY=

# ── Facebook Marketplace ──────────────────────────────────────────────────────
# Scraping only — requires session cookies from a logged-in browser session
FB_MARKETPLACE_COOKIE=

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-project-id
GCS_BUCKET=price-intelligence-raw
GCP_KEYFILE_PATH=~/.gcp/keyfile.json

# ── AWS (alternative to GCS) ──────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=price-intelligence-raw

# ── Snowflake (alternative to BigQuery) ───────────────────────────────────────
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_DATABASE=PRICE_INTELLIGENCE
# SNOWFLAKE_WAREHOUSE=TRANSFORM_WH

# ── Alerting ──────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_DATABASE=price_intelligence
DBT_TARGET=dev                  # dev (DuckDB) | prod_bq (BigQuery) | prod_snowflake

